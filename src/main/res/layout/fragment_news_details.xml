<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:paddingTop="@dimen/action_bar_size_static">

    <ScrollView
        android:id="@+id/scrollview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <RelativeLayout
            android:id="@+id/this_news"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="?android:attr/listPreferredItemHeightLarge"
            android:paddingBottom="@dimen/baseline_16">

            <ImageView
                android:id="@+id/thumbnail"
                android:layout_width="match_parent"
                android:layout_height="@dimen/baseline_192"
                android:layout_alignWithParentIfMissing="true"
                android:layout_alignParentTop="true"
                android:layout_marginBottom="@dimen/baseline_8"
                android:scaleType="fitCenter"
                android:visibility="gone"
                tools:src="@tools:sample/backgrounds/scenic"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/thumbnail"
                android:layout_alignParentRight="true"
                android:layout_marginLeft="@dimen/baseline_16"
                android:layout_marginRight="@dimen/baseline_16"
                android:background="?android:attr/selectableItemBackground"
                android:fontFamily="sans-serif-condensed"
                android:maxLines="1"
                android:padding="1dp"
                android:textAppearance="?android:attr/textAppearanceSmall"
                android:textColor="?android:attr/textColorTertiary"
                tools:text="@tools:sample/date/day_of_week" />

            <TextView
                android:id="@+id/newsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/date"
                android:layout_alignParentBottom="true"
                android:layout_marginLeft="@dimen/baseline_16"
                android:layout_marginTop="8dp"
                android:layout_marginRight="@dimen/baseline_16"
                android:ellipsize="end"
                android:fontFamily="sans-serif-condensed"
                android:textAppearance="?android:attr/textAppearanceMedium"
                android:textColor="?android:attr/textColorPrimary"
                android:textStyle="normal"
                tools:text="@tools:sample/lorem/random" />

        </RelativeLayout>

    </ScrollView>

    <include layout="@layout/layout_shadow" />

</FrameLayout>